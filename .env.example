NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_API_VERSION=

# Which portfolio template to render. Inlined at build time (rebuild to change).
#   emerald = light emerald + gold, N monogram (default)
#   classic = numbered syllabus rail, Bricolage Grotesque, dark-mode
NEXT_PUBLIC_PORTFOLIO_TEMPLATE=emerald
